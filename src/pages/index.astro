---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// Fetch all non-draft posts, sorted newest first
const allPosts = (
  await getCollection('posts', ({ data }) => !data.draft)
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Group posts by year for timeline display
const postsByYear = allPosts.reduce<Record<number, typeof allPosts>>(
  (acc, post) => {
    const year = post.data.date.getFullYear();
    if (!acc[year]) acc[year] = [];
    acc[year].push(post);
    return acc;
  },
  {}
);

const years = Object.keys(postsByYear)
  .map(Number)
  .sort((a, b) => b - a);

// Collect all unique tags
const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags))].sort();
---

<Layout
  title="Cyanix Blog"
  description="Personal blog by Cyanix — notes, thoughts, and technical writings."
>
  <!-- ── Hero ── -->
  <section class="mb-14 pt-4">
    <p class="mb-1 font-mono text-sm text-cyan-500">hi, I'm</p>
    <h1 class="mb-3 text-4xl font-bold tracking-tight text-zinc-50 sm:text-5xl">
      Cyanix
    </h1>
    <p class="max-w-xl text-base leading-relaxed text-zinc-400">
      记录技术思考与日常笔记。用 Obsidian 写作，Git 同步，Astro 构建，Vercel 部署。
    </p>

    <!-- Stats bar -->
    <div class="mt-6 flex flex-wrap gap-6 text-sm text-zinc-500">
      <span>
        <span class="font-semibold text-zinc-300">{allPosts.length}</span>
        {' '}篇文章
      </span>
      <span>
        <span class="font-semibold text-zinc-300">{allTags.length}</span>
        {' '}个标签
      </span>
      <span>
        <span class="font-semibold text-zinc-300">{years.length}</span>
        {' '}年
      </span>
    </div>
  </section>

  <!-- ── Search box (progressive enhancement — Pagefind will hook into this) ── -->
  <section class="mb-10" aria-label="搜索文章">
    <div class="relative">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="absolute left-3 top-1/2 -translate-y-1/2 text-zinc-500"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input
        id="post-search"
        type="search"
        placeholder="搜索文章标题或标签…"
        autocomplete="off"
        class="w-full rounded-lg border border-zinc-800 bg-zinc-900 py-2.5 pl-9 pr-4 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition focus:border-cyan-700 focus:ring-1 focus:ring-cyan-700"
        aria-label="搜索文章"
      />
    </div>
  </section>

  <!-- ── Tag filter chips ── -->
  {
    allTags.length > 0 && (
      <section class="mb-10" aria-label="标签筛选">
        <div
          id="tag-filter"
          class="flex flex-wrap gap-2"
          role="group"
          aria-label="按标签筛选"
        >
          <button
            data-tag=""
            class="tag-chip rounded-full border border-zinc-700 bg-zinc-900 px-3 py-1 text-xs text-zinc-400 transition hover:border-cyan-700 hover:text-cyan-400 aria-pressed:border-cyan-600 aria-pressed:bg-cyan-950/60 aria-pressed:text-cyan-400"
            aria-pressed="true"
          >
            全部
          </button>
          {allTags.map((tag) => (
            <button
              data-tag={tag}
              class="tag-chip rounded-full border border-zinc-700 bg-zinc-900 px-3 py-1 text-xs text-zinc-400 transition hover:border-cyan-700 hover:text-cyan-400 aria-pressed:border-cyan-600 aria-pressed:bg-cyan-950/60 aria-pressed:text-cyan-400"
              aria-pressed="false"
            >
              #{tag}
            </button>
          ))}
        </div>
      </section>
    )
  }

  <!-- ── Post list (timeline grouped by year) ── -->
  <section aria-label="文章列表" id="post-list">
    {
      allPosts.length === 0 ? (
        <div class="flex flex-col items-center justify-center py-20 text-zinc-600">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="40"
            height="40"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="mb-4 opacity-40"
          >
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
            <polyline points="14 2 14 8 20 8" />
            <line x1="16" y1="13" x2="8" y2="13" />
            <line x1="16" y1="17" x2="8" y2="17" />
            <polyline points="10 9 9 9 8 9" />
          </svg>
          <p class="text-sm">暂无文章，快去 Obsidian 写点什么吧！</p>
        </div>
      ) : (
        years.map((year) => (
          <div class="year-group mb-10" data-year={year}>
            <!-- Year marker -->
            <div class="mb-4 flex items-center gap-3">
              <span class="font-mono text-sm font-semibold text-cyan-500">
                {year}
              </span>
              <div class="h-px flex-1 bg-zinc-800" />
            </div>

            <!-- Posts for this year -->
            <ul class="space-y-1">
              {postsByYear[year].map((post) => {
                const monthDay = post.data.date.toLocaleDateString('zh-CN', {
                  month: '2-digit',
                  day: '2-digit',
                });
                const postTags = post.data.tags;

                return (
                  <li
                    class="post-item group"
                    data-title={post.data.title.toLowerCase()}
                    data-tags={postTags.join(' ').toLowerCase()}
                  >
                    <a
                      href={`/posts/${post.id}`}
                      class="flex items-baseline gap-4 rounded-md px-2 py-2.5 transition hover:bg-zinc-900"
                    >
                      <!-- Date -->
                      <time
                        datetime={post.data.date.toISOString()}
                        class="w-12 shrink-0 font-mono text-xs text-zinc-600 group-hover:text-zinc-500"
                      >
                        {monthDay}
                      </time>

                      <!-- Title -->
                      <span class="flex-1 text-sm text-zinc-300 group-hover:text-zinc-100">
                        {post.data.title}
                      </span>

                      <!-- Tags (hidden on small screens) -->
                      {postTags.length > 0 && (
                        <span class="hidden shrink-0 items-center gap-1.5 sm:flex">
                          {postTags.slice(0, 3).map((tag) => (
                            <span class="rounded px-1.5 py-0.5 text-xs text-zinc-600 ring-1 ring-zinc-800">
                              {tag}
                            </span>
                          ))}
                          {postTags.length > 3 && (
                            <span class="text-xs text-zinc-700">
                              +{postTags.length - 3}
                            </span>
                          )}
                        </span>
                      )}

                      <!-- Arrow -->
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="shrink-0 text-zinc-700 transition group-hover:translate-x-0.5 group-hover:text-cyan-600"
                        aria-hidden="true"
                      >
                        <line x1="5" y1="12" x2="19" y2="12" />
                        <polyline points="12 5 19 12 12 19" />
                      </svg>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        ))
      )
    }

    <!-- Empty state shown by JS when search/filter yields no results -->
    <p
      id="no-results"
      class="hidden py-16 text-center text-sm text-zinc-600"
      role="status"
      aria-live="polite"
    >
      没有找到匹配的文章。
    </p>
  </section>
</Layout>

<script>
  // ── Client-side search + tag filter ──────────────────────────────────────

  const searchInput = document.getElementById(
    'post-search'
  ) as HTMLInputElement | null;
  const tagChips = document.querySelectorAll<HTMLButtonElement>('.tag-chip');
  const postItems = document.querySelectorAll<HTMLLIElement>('.post-item');
  const yearGroups = document.querySelectorAll<HTMLDivElement>('.year-group');
  const noResults = document.getElementById('no-results');

  let activeTag = '';
  let searchQuery = '';

  function applyFilters() {
    let visibleCount = 0;

    postItems.forEach((item) => {
      const title = item.dataset.title ?? '';
      const tags = item.dataset.tags ?? '';

      const matchesSearch =
        searchQuery === '' || title.includes(searchQuery) || tags.includes(searchQuery);
      const matchesTag =
        activeTag === '' || tags.split(' ').includes(activeTag.toLowerCase());

      const visible = matchesSearch && matchesTag;
      item.style.display = visible ? '' : 'none';
      if (visible) visibleCount++;
    });

    // Hide year groups that have no visible posts
    yearGroups.forEach((group) => {
      const hasVisible = [...group.querySelectorAll<HTMLLIElement>('.post-item')].some(
        (el) => el.style.display !== 'none'
      );
      group.style.display = hasVisible ? '' : 'none';
    });

    if (noResults) {
      noResults.classList.toggle('hidden', visibleCount > 0);
    }
  }

  // Search
  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value.trim().toLowerCase();
    applyFilters();
  });

  // Tag chips
  tagChips.forEach((chip) => {
    chip.addEventListener('click', () => {
      const tag = chip.dataset.tag ?? '';
      activeTag = tag;

      tagChips.forEach((c) => c.setAttribute('aria-pressed', 'false'));
      chip.setAttribute('aria-pressed', 'true');

      applyFilters();
    });
  });
</script>
