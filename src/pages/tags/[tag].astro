---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
    const allPosts = await getCollection("posts", ({ data }) => !data.draft);

    const tags = [...new Set(allPosts.flatMap((post) => post.data.tags))];

    return tags.map((tag) => ({
        params: { tag: tag.toLowerCase().replace(/\s+/g, "-") },
        props: {
            tag,
            posts: allPosts
                .filter((post) => post.data.tags.includes(tag))
                .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
        },
    }));
}

const { tag, posts } = Astro.props;
---

<Layout
    title={`#${tag}`}
    description={`标签「${tag}」下的所有文章，共 ${posts.length} 篇。`}
>
    <header class="mb-10 border-b border-zinc-800 pb-8">
        <div class="mb-2 flex items-center gap-3">
            <a
                href="/tags"
                class="text-sm text-zinc-500 transition hover:text-cyan-400"
                aria-label="返回标签列表"
            >
                标签
            </a>
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-zinc-700"
                aria-hidden="true"
            >
                <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
            <span class="text-sm text-zinc-400">{tag}</span>
        </div>

        <h1 class="mb-2 text-3xl font-bold tracking-tight text-zinc-50">
            <span class="font-mono text-cyan-500">#</span>{tag}
        </h1>
        <p class="text-sm text-zinc-500">
            共 <span class="font-medium text-zinc-300">{posts.length}</span> 篇文章
        </p>
    </header>

    {
        posts.length === 0 ? (
            <div class="flex flex-col items-center justify-center py-20 text-zinc-600">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="40"
                    height="40"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="mb-4 opacity-40"
                >
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                    <polyline points="14 2 14 8 20 8" />
                    <line x1="16" y1="13" x2="8" y2="13" />
                    <line x1="16" y1="17" x2="8" y2="17" />
                    <polyline points="10 9 9 9 8 9" />
                </svg>
                <p class="text-sm">该标签下暂无文章。</p>
            </div>
        ) : (
            <ul class="space-y-1">
                {posts.map((post) => {
                    const formattedDate = post.data.date.toLocaleDateString(
                        "zh-CN",
                        {
                            year: "numeric",
                            month: "2-digit",
                            day: "2-digit",
                        },
                    );
                    const otherTags = post.data.tags.filter((t) => t !== tag);

                    return (
                        <li class="group">
                            <a
                                href={`/posts/${post.id}`}
                                class="flex items-baseline gap-4 rounded-md px-2 py-2.5 transition hover:bg-zinc-900"
                            >
                                <time
                                    datetime={post.data.date.toISOString()}
                                    class="w-28 shrink-0 font-mono text-xs text-zinc-600 group-hover:text-zinc-500"
                                >
                                    {formattedDate}
                                </time>

                                <span class="flex-1 text-sm text-zinc-300 group-hover:text-zinc-100">
                                    {post.data.title}
                                </span>

                                {otherTags.length > 0 && (
                                    <span class="hidden shrink-0 items-center gap-1.5 sm:flex">
                                        {otherTags.slice(0, 2).map((t) => (
                                            <span class="rounded px-1.5 py-0.5 text-xs text-zinc-600 ring-1 ring-zinc-800">
                                                {t}
                                            </span>
                                        ))}
                                        {otherTags.length > 2 && (
                                            <span class="text-xs text-zinc-700">
                                                +{otherTags.length - 2}
                                            </span>
                                        )}
                                    </span>
                                )}

                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="14"
                                    height="14"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="shrink-0 text-zinc-700 transition group-hover:translate-x-0.5 group-hover:text-cyan-600"
                                    aria-hidden="true"
                                >
                                    <line x1="5" y1="12" x2="19" y2="12" />
                                    <polyline points="12 5 19 12 12 19" />
                                </svg>
                            </a>
                        </li>
                    );
                })}
            </ul>
        )
    }

    <div class="mt-10">
        <a
            href="/tags"
            class="inline-flex items-center gap-2 text-sm text-zinc-500 transition hover:text-cyan-400"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
            >
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            返回标签列表
        </a>
    </div>
</Layout>
