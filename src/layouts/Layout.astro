---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import { ClientRouter } from "astro:transitions";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  pubDate?: Date;
  tags?: string[];
  type?: "website" | "article";
}

const {
  title = "Cyanix Blog",
  description = "Personal blog by Cyanix — notes, thoughts, and technical writings.",
  ogImage = "/og-default.png",
  pubDate,
  tags = [],
  type = "website",
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://cyanix-blog.vercel.app");
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const fullTitle = title === "Cyanix Blog" ? title : `${title} · Cyanix Blog`;
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" type="image/ico" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Primary Meta -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {tags.length > 0 && <meta name="keywords" content={tags.join(", ")} />}
    <meta name="author" content="Cyanix" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, siteUrl)} />
    <meta property="og:site_name" content="Cyanix Blog" />
    <meta property="og:locale" content="zh_CN" />
    {
      pubDate && (
        <meta
          property="article:published_time"
          content={pubDate.toISOString()}
        />
      )
    }

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, siteUrl)} />

    <!-- RSS -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Cyanix Blog RSS"
      href="/rss.xml"
    />

    <!-- Theme colour (matches --color-accent in CSS) -->
    <meta name="theme-color" content="#06b6d4" />

    <!-- Smooth Animations -->
    <ClientRouter />

    <!-- FOUC Prevention for Theme -->
    <script is:inline>
      (function () {
        const theme = localStorage.getItem("cyanix-theme") || "auto";
        if (theme !== "auto") {
          document.documentElement.setAttribute("data-theme", theme);
        }
      })();
    </script>
  </head>

  <body class="bg-surface text-text min-h-screen flex flex-col antialiased">
    <!-- ── Navigation ── -->
    <header
      class="sticky top-0 z-50 border-b border-surface-2 bg-surface/80 backdrop-blur-md"
    >
      <nav
        class="mx-auto flex max-w-3xl items-center justify-between px-4 py-3"
      >
        <a
          href="/"
          class="font-mono text-lg font-bold tracking-tight text-accent hover:text-accent/80 transition-colors"
        >
          ~/cyanix
        </a>

        <ul class="flex items-center gap-6 text-sm text-text-muted">
          <li>
            <a href="/" class="hover:text-accent transition-colors">Posts</a>
          </li>
          <li>
            <a href="/tags" class="hover:text-accent transition-colors">Tags</a>
          </li>
          <li>
            <a href="/about" class="hover:text-accent transition-colors"
              >About</a
            >
          </li>
          <li>
            <a
              href="https://github.com/Cyanix-0721"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-accent transition-colors block"
              aria-label="GitHub"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"
                ></path>
              </svg>
            </a>
          </li>
          <li>
            <button
              id="theme-toggle"
              class="flex items-center justify-center p-1.5 rounded-lg border border-surface-2 bg-surface-1 text-text-muted hover:text-accent hover:border-accent-dim transition-all cursor-pointer"
              aria-label="Switch theme"
              title="Theme Toggle"
            >
              <span class="theme-icon-container">
                <!-- Icon will be injected by script -->
              </span>
            </button>
          </li>
        </ul>
      </nav>
    </header>

    <!-- ── Main Content ── -->
    <main class="mx-auto w-full max-w-3xl flex-1 px-4 py-10">
      <slot />
    </main>

    <!-- ── Footer ── -->
    <footer
      class="border-t border-surface-2 py-6 text-center text-sm text-text-muted"
    >
      <p>
        &copy; {new Date().getFullYear()} Cyanix &middot; Built with
        <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent hover:text-accent/80 transition-colors">Astro</a
        >
        &middot; Deployed on
        <a
          href="https://vercel.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent hover:text-accent/80 transition-colors">Vercel</a
        >
      </p>
    </footer>

    <script>
      import { initThemeSwitcher } from "../scripts/theme-manager";
      import { addCopyButtonsForCodeBlocks } from "../scripts/code-block-copy";

      // Initialize on page load
      initThemeSwitcher();
      addCopyButtonsForCodeBlocks();

      // Support for Astro ViewTransitions
      document.addEventListener("astro:after-swap", () => {
        initThemeSwitcher();
        addCopyButtonsForCodeBlocks();
      });
    </script>

    <Analytics />
    <SpeedInsights />
  </body>
</html>
