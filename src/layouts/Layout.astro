---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  pubDate?: Date;
  tags?: string[];
  type?: "website" | "article";
}

const {
  title = "Cyanix Blog",
  description = "Personal blog by Cyanix — notes, thoughts, and technical writings.",
  ogImage = "/og-default.png",
  pubDate,
  tags = [],
  type = "website",
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://cyanix-blog.vercel.app");
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const fullTitle = title === "Cyanix Blog" ? title : `${title} · Cyanix Blog`;
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Primary Meta -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {tags.length > 0 && <meta name="keywords" content={tags.join(", ")} />}
    <meta name="author" content="Cyanix" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, siteUrl)} />
    <meta property="og:site_name" content="Cyanix Blog" />
    <meta property="og:locale" content="zh_CN" />
    {
      pubDate && (
        <meta
          property="article:published_time"
          content={pubDate.toISOString()}
        />
      )
    }

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, siteUrl)} />

    <!-- RSS -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Cyanix Blog RSS"
      href="/rss.xml"
    />

    <!-- Theme colour (matches --color-accent in CSS) -->
    <meta name="theme-color" content="#06b6d4" />
  </head>

  <body
    class="bg-zinc-950 text-zinc-100 min-h-screen flex flex-col antialiased"
  >
    <!-- ── Navigation ── -->
    <header
      class="sticky top-0 z-50 border-b border-zinc-800 bg-zinc-950/80 backdrop-blur-md"
    >
      <nav
        class="mx-auto flex max-w-3xl items-center justify-between px-4 py-3"
      >
        <a
          href="/"
          class="font-mono text-lg font-bold tracking-tight text-cyan-400 hover:text-cyan-300 transition-colors"
        >
          ~/cyanix
        </a>

        <ul class="flex items-center gap-6 text-sm text-zinc-400">
          <li>
            <a href="/" class="hover:text-cyan-400 transition-colors">Posts</a>
          </li>
          <li>
            <a href="/tags" class="hover:text-cyan-400 transition-colors"
              >Tags</a
            >
          </li>
          <li>
            <a href="/about" class="hover:text-cyan-400 transition-colors"
              >About</a
            >
          </li>
          <li>
            <a
              href="https://github.com/Cyanix-0721"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-cyan-400 transition-colors"
              aria-label="GitHub"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"
                ></path>
              </svg>
            </a>
          </li>
        </ul>
      </nav>
    </header>

    <!-- ── Main Content ── -->
    <main class="mx-auto w-full max-w-3xl flex-1 px-4 py-10">
      <slot />
    </main>

    <!-- ── Footer ── -->
    <footer
      class="border-t border-zinc-800 py-6 text-center text-sm text-zinc-500"
    >
      <p>
        &copy; {new Date().getFullYear()} Cyanix &middot; Built with
        <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="text-cyan-500 hover:text-cyan-400 transition-colors">Astro</a
        >
        &middot; Deployed on
        <a
          href="https://vercel.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-cyan-500 hover:text-cyan-400 transition-colors">Vercel</a
        >
      </p>
    </footer>

    <script>
      // Code block copy button functionality
      function addCopyButtons() {
        const codeBlocks = document.querySelectorAll("pre");

        codeBlocks.forEach((codeBlock) => {
          // Check if button already exists (to avoid duplicates on soft navigation if any)
          if (codeBlock.querySelector(".copy-button")) return;

          const button = document.createElement("button");
          button.className = "copy-button";
          button.type = "button";
          button.ariaLabel = "Copy code to clipboard";
          button.title = "Copy code";
          button.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`;

          codeBlock.appendChild(button);

          button.addEventListener("click", async () => {
            const code = codeBlock.querySelector("code");
            const text = code ? code.innerText : codeBlock.innerText;

            try {
              await navigator.clipboard.writeText(text);

              // Success state
              button.classList.add("copied");
              button.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;

              setTimeout(() => {
                button.classList.remove("copied");
                button.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`;
              }, 2000);
            } catch (err) {
              console.error("Failed to copy text: ", err);
            }
          });
        });
      }

      // Initialize on page load
      addCopyButtons();

      // Support for ViewTransitions if added in the future
      document.addEventListener("astro:after-swap", addCopyButtons);
    </script>

    <Analytics />
    <SpeedInsights />
  </body>
</html>
