---
import Layout from "./Layout.astro";

export interface Props {
    title: string;
    date: Date;
    description?: string;
    tags?: string[];
    cover?: string;
    minutesRead?: number;
}

const { title, date, description, tags = [], cover, minutesRead } = Astro.props;

const formattedDate = date.toLocaleDateString("zh-CN", {
    year: "numeric",
    month: "long",
    day: "numeric",
});

const isoDate = date.toISOString();
---

<Layout
    title={title}
    description={description}
    ogImage={cover}
    pubDate={date}
    tags={tags}
    type="article"
>
    <article>
        <!-- Post Header -->
        <header class="mb-10 border-b border-zinc-800 pb-8">
            {
                cover && (
                    <div class="mb-8 overflow-hidden rounded-xl">
                        <img
                            src={cover}
                            alt={title}
                            class="h-64 w-full object-cover transition-transform duration-500 hover:scale-105"
                            loading="eager"
                        />
                    </div>
                )
            }

            <!-- Tags -->
            {
                tags.length > 0 && (
                    <div class="mb-4 flex flex-wrap gap-2">
                        {tags.map((tag) => (
                            <a
                                href={`/tags/${tag.toLowerCase().replace(/\s+/g, "-")}`}
                                class="rounded-full bg-cyan-950/60 px-3 py-0.5 text-xs font-medium text-cyan-400 ring-1 ring-cyan-800/50 transition-colors hover:bg-cyan-900/60 hover:text-cyan-300"
                            >
                                #{tag}
                            </a>
                        ))}
                    </div>
                )
            }

            <!-- Title -->
            <h1
                class="mb-4 text-3xl font-bold leading-tight tracking-tight text-zinc-50 sm:text-4xl"
            >
                {title}
            </h1>

            <!-- Description -->
            {
                description && (
                    <p class="mb-5 text-lg leading-relaxed text-zinc-400">
                        {description}
                    </p>
                )
            }

            <!-- Meta: date + reading time -->
            <div
                class="flex flex-wrap items-center gap-3 text-sm text-zinc-500"
            >
                <time datetime={isoDate} class="flex items-center gap-1.5">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"
                        ></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                    {formattedDate}
                </time>

                {
                    minutesRead && (
                        <>
                            <span aria-hidden="true" class="text-zinc-700">
                                ·
                            </span>
                            <span class="flex items-center gap-1.5">
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="14"
                                    height="14"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    aria-hidden="true"
                                >
                                    <circle cx="12" cy="12" r="10" />
                                    <polyline points="12 6 12 12 16 14" />
                                </svg>
                                {minutesRead} 分钟阅读
                            </span>
                        </>
                    )
                }
            </div>
        </header>

        <!-- Post Body -->
        <div class="prose">
            <slot />
        </div>

        <!-- Post Footer: tag list -->
        {
            tags.length > 0 && (
                <footer class="mt-12 border-t border-zinc-800 pt-8">
                    <p class="mb-3 text-sm font-medium text-zinc-400">标签</p>
                    <div class="flex flex-wrap gap-2">
                        {tags.map((tag) => (
                            <a
                                href={`/tags/${tag.toLowerCase().replace(/\s+/g, "-")}`}
                                class="rounded-full bg-zinc-800 px-3 py-1 text-sm text-zinc-300 transition-colors hover:bg-cyan-950/60 hover:text-cyan-400"
                            >
                                #{tag}
                            </a>
                        ))}
                    </div>
                </footer>
            )
        }

        <!-- Back link -->
        <div class="mt-10">
            <a
                href="/"
                class="inline-flex items-center gap-2 text-sm text-zinc-500 transition-colors hover:text-cyan-400"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                返回文章列表
            </a>
        </div>
    </article>
</Layout>
